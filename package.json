{
  "name": "twotails",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:doppler": "doppler.exe run -- next dev",
    "build": "next build",
    "build:doppler": "doppler.exe run -- next build",
    "start": "next start",
    "start:doppler": "doppler.exe run -- next start",
    "assets:about": "node scripts/download-about-assets.mjs",
    "assets:benefits": "node scripts/download-benefits-assets.mjs",
    "assets:checkout": "node scripts/download-checkout-assets.mjs",
    "assets:feeding": "node scripts/download-feeding-assets.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "doppler:login": "doppler.exe login",
    "doppler:setup": "doppler.exe setup --project twotails --config dev"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "shadcn": "^4.0.8",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
